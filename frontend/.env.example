DATABASE_URL=postgres://postgres_user:postgres_password@localhost/getraenke

# better-auth settings
BETTER_AUTH_SECRET=change-me-to-a-random-secret-of-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# OIDC provider settings
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_DISCOVERY_URL=https://your-oidc-provider/.well-known/openid-configuration
