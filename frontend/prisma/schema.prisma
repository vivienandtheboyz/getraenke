// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Allergen {
  symbol String @id
  name   String

  products Product[]
}

model Organization {
  organizationId String  @id @default(uuid()) @db.Uuid
  name           String
  logo           String?
  logoDark       String?
  banner         String?

  catalogues Catalogue[]
  users      User[]
}

model Catalogue {
  catalogueId String  @id @default(uuid()) @db.Uuid
  name        String
  logo        String?
  logoDark    String?
  banner      String?

  organization   Organization @relation(fields: [organizationId], references: [organizationId])
  organizationId String       @db.Uuid
  products       Product[]
}

model Product {
  productId String @id @default(uuid()) @db.Uuid

  catalogue   Catalogue @relation(fields: [catalogueId], references: [catalogueId])
  catalogueId String    @db.Uuid

  size Int
  unit String

  inventory Int
  name      String
  image     String?
  gtin      String?

  // energy in kJ
  energy       Int?
  // protein in g
  protein      Int?
  // fat total in g
  fatTotal     Int?
  // fat saturated in g
  fatSaturated Int?
  // carbohydrate in g
  carbohydrate Int?
  // sugar in g
  sugar        Int?
  // sodium in mg
  sodium       Int?

  vegan      Boolean
  vegetarian Boolean
  halal      Boolean
  kosher     Boolean

  allergens Allergen[]

  prices       ProductPrice[]
  deposits     DepositValue[]
  invoiceItems InvoiceItem[]
}

model ProductPrice {
  price Int
  start DateTime
  end   DateTime?

  product   Product @relation(fields: [productId], references: [productId])
  productId String  @db.Uuid

  @@id([productId, start])
}

// If § 31 (1) VerpackG should ever change 💹
model DepositValue {
  value Int
  start DateTime
  end   DateTime?

  product   Product @relation(fields: [productId], references: [productId])
  productId String  @db.Uuid

  @@id([productId, start])
  @@map("DepositHistory")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Application fields
  balance        Int       @default(0)
  organizationId String?   @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [organizationId])

  sessions Session[]
  accounts Account[]

  invoices Invoice[]
  topUps   TopUp[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String    @id
  identifier String
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([identifier, value])
}

model Invoice {
  invoiceId String   @id @default(uuid()) @db.Uuid
  timestamp DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String @db.Uuid

  positions InvoiceItem[]
}

model InvoiceItem {
  quantity Int @default(1)
  discount Int

  product   Product @relation(fields: [productId], references: [productId])
  productId String  @db.Uuid

  invoice   Invoice @relation(fields: [invoiceId], references: [invoiceId])
  invoiceId String  @db.Uuid

  @@id([productId, invoiceId])
}

model TopUp {
  topUpId   String   @id @default(uuid()) @db.Uuid
  amount    Int
  timestamp DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String @db.Uuid
}
